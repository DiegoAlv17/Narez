---
import { landingData } from '../data/landing';
---

<section id="servicios" class="py-32 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-24 feature-header">
      <h2 class="text-5xl md:text-8xl font-bold text-slate-900 uppercase tracking-tighter leading-none">
        Nuestros <br/><span class="text-blue-600">Servicios</span>
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-16 gap-y-20 features-grid">
      {landingData.features.map((feature, idx) => (
        <div class="group cursor-pointer feature-card">
          <!-- LÃ­nea superior animada tipo corporativo -->
          <div class="h-1 bg-slate-200 mb-8 relative overflow-hidden">
            <div class="absolute inset-y-0 left-0 w-0 bg-blue-600 group-hover:w-full transition-all duration-700 ease-out"></div>
          </div>
          <h3 class="text-3xl md:text-5xl font-bold text-slate-900 mb-6 group-hover:text-blue-600 transition-colors uppercase tracking-tighter leading-none">{feature.title}</h3>
          <p class="text-xl text-slate-600 leading-relaxed font-medium mb-10 max-w-lg">
            {feature.description}
          </p>
          <div class="flex items-center text-blue-600 font-semibold group-hover:text-blue-800 transition-colors">
            <span class="mr-4 uppercase tracking-widest text-sm">Explorar</span>
            <svg class="w-6 h-6 transform group-hover:translate-x-3 transition-transform duration-300" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="square" stroke-linejoin="miter" d="M9 5l7 7-7 7"></path></svg>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  import gsap from "gsap";
  import ScrollTrigger from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const mm = gsap.matchMedia();

  mm.add("(prefers-reduced-motion: no-preference)", () => {
    // AnimaciÃ³n de entrada para el tÃ­tulo principal
    gsap.from(".feature-header h2", {
      scrollTrigger: {
        trigger: ".feature-header",
        start: "top 80%",
        toggleActions: "play reverse play reverse" // Se reproduce al bajar, se invierte al subir
      },
      y: 60,
      autoAlpha: 0,
      duration: 1,
      ease: "power3.out"
    });

    // AnimaciÃ³n escalonada (staggered) de cada tarjeta 
    // Usamos el grid como trigger para que inicien en cascada
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: ".features-grid",
        start: "top 80%", // Se activa cuando el grid alcanza el 80% de la pantalla
        toggleActions: "play reverse play reverse" // Permite repetir la animaciÃ³n en ambos sentidos
      }
    });

    tl.from(".feature-card", {
      y: 80,
      autoAlpha: 0,
      duration: 0.8,
      stagger: 0.15,
      ease: "power2.out"
    });
  });
</script>

