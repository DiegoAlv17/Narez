---
import { landingData } from '../data/landing';
---

<section id="servicios" class="py-32 bg-slate-950">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-24 feature-header">
      <h2 class="text-5xl md:text-8xl font-bold text-white uppercase tracking-tighter leading-none inline-block">
        Nuestros <br/><span class="text-blue-500">Servicios</span>
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 features-grid">
      {landingData.features.map((feature, idx) => (
        <div class="group cursor-pointer feature-card relative overflow-hidden bg-slate-900/50 border border-slate-800 flex flex-col p-8 transition-colors duration-500 hover:border-blue-500/50 hover:shadow-2xl hover:shadow-blue-500/10">
          
          <div class="text-xs font-bold tracking-widest text-slate-500 mb-6 uppercase shrink-0">Servicio</div>
          
          <h3 class="text-2xl font-bold text-white leading-tight mb-6 transition-colors duration-500 group-hover:text-blue-400">
            {feature.title}
          </h3>
          
          <p class="text-lg text-slate-300 leading-relaxed font-medium mb-auto">
            {feature.description}
          </p>

          <div class="flex items-center text-white font-bold group-hover:text-blue-400 transition-colors mt-12">
            <span class="mr-4 uppercase tracking-widest text-sm">Explorar</span>
            <svg class="w-5 h-5 transform group-hover:translate-x-2 transition-transform duration-300" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="square" stroke-linejoin="miter" d="M9 5l7 7-7 7"></path></svg>
          </div>
          
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  import gsap from "gsap";
  import ScrollTrigger from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const mm = gsap.matchMedia();

  mm.add("(prefers-reduced-motion: no-preference)", () => {
    // Animación de entrada para el título principal
    gsap.from(".feature-header h2", {
      scrollTrigger: {
        trigger: ".feature-header",
        start: "top 80%",
        toggleActions: "play reverse play reverse" // Se reproduce al bajar, se invierte al subir
      },
      y: 60,
      autoAlpha: 0,
      duration: 1,
      ease: "power3.out"
    });

    // Animación escalonada (staggered) de cada tarjeta 
    // Usamos el grid como trigger para que inicien en cascada
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: ".features-grid",
        start: "top 80%", // Se activa cuando el grid alcanza el 80% de la pantalla
        toggleActions: "play reverse play reverse" // Permite repetir la animación en ambos sentidos
      }
    });

    tl.from(".feature-card", {
      y: 80,
      autoAlpha: 0,
      duration: 0.8,
      stagger: 0.15,
      ease: "power2.out"
    });
  });
</script>
