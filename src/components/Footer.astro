---
import { siteConfig } from '../config/site';

const currentYear = new Date().getFullYear();
---

<footer class="bg-slate-950 pt-24 pb-12 overflow-hidden border-t border-slate-900 border-t-blue-600">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 lg:gap-8 border-b border-slate-800 pb-16">
      
      <div class="md:col-span-5 lg:col-span-6">
        <a href="/" class="inline-flex items-center group gap-3" aria-label={`Ir al inicio - ${siteConfig.name}`}>
          <img src="/logo.svg" alt={`Logo de ${siteConfig.name}`} class="h-10 w-auto invert brightness-0 transition-transform duration-300 group-hover:scale-110 relative z-10" />
          <span class="font-syne font-semibold text-3xl tracking-tighter text-white uppercase max-w-0 opacity-0 -translate-x-4 transition-all duration-500 ease-in-out group-hover:max-w-[200px] group-hover:opacity-100 group-hover:translate-x-0 overflow-hidden whitespace-nowrap">{siteConfig.name}</span>
        </a>
        <p class="mt-8 text-lg font-medium text-slate-400 max-w-sm leading-relaxed">
          {siteConfig.description}
        </p>
      </div>
      
      <div class="md:col-span-7 lg:col-span-6 grid grid-cols-2 gap-8">
        <div>
          <h4 class="text-xs font-semibold text-slate-500 uppercase tracking-widest mb-6">Navegación</h4>
          <ul class="space-y-4">
            <li><a href="#servicios" class="text-sm font-semibold text-slate-300 hover:text-white uppercase transition-colors">Servicios</a></li>
            <li><a href="#nosotros" class="text-sm font-semibold text-slate-300 hover:text-white uppercase transition-colors">Nosotros</a></li>
            <li><a href="#contacto" class="text-sm font-semibold text-slate-300 hover:text-white uppercase transition-colors">Contacto</a></li>
          </ul>
        </div>
        <div>
          <h4 class="text-xs font-semibold text-slate-500 uppercase tracking-widest mb-6">Redes</h4>
          <ul class="space-y-4">
            <li><a href={siteConfig.social.twitter} class="text-sm font-semibold text-slate-300 hover:text-white uppercase transition-colors" target="_blank" rel="noopener noreferrer">Twitter X</a></li>
            <li><a href={siteConfig.social.github} class="text-sm font-semibold text-slate-300 hover:text-white uppercase transition-colors" target="_blank" rel="noopener noreferrer">GitHub</a></li>
          </ul>
        </div>
      </div>
    </div>
    
    <div class="mt-12 flex flex-col md:flex-row md:items-center md:justify-between items-start">
      <p class="text-sm font-bold text-slate-600 uppercase tracking-wider">
        &copy; {currentYear} {siteConfig.name}. Todos los derechos reservados.
      </p>
      <div class="mt-4 md:mt-0 flex space-x-6">
        <a href="#" class="text-xs font-bold text-slate-600 hover:text-slate-400 uppercase tracking-wider transition-colors">Aviso de Privacidad</a>
        <a href="#" class="text-xs font-bold text-slate-600 hover:text-slate-400 uppercase tracking-wider transition-colors">Términos de Uso</a>
      </div>
    </div>
  </div>
</footer>
