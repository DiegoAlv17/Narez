---
import { landingData } from '../data/landing';
---

<section id="proceso" class="relative bg-slate-950">
  <!-- Decorative background elements -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-slate-900 via-slate-950 to-slate-950 -z-10"></div>
    <div class="absolute top-1/4 right-0 w-96 h-96 bg-blue-600/10 rounded-full blur-3xl -z-10"></div>
  </div>

  <div class="relative w-full z-10">
    <!-- Sticky Title Section -->
    <div class="sticky top-0 h-screen w-full flex flex-col items-center justify-center z-0 px-4 text-center process-title-container">
      <div class="space-y-6">
        <p class="text-sm md:text-base font-semibold tracking-widest text-blue-500 uppercase process-subtitle">Nuestro proceso</p>
        <h2 class="text-5xl md:text-7xl lg:text-8xl font-bold text-white  process-title">
          Claridad en <br class="hidden md:block" /><span class="text-blue-500">cada etapa.</span>
        </h2>
      </div>
    </div>

    <!-- Scrolling Steps Section (Elevator Effect) -->
    <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pt-[50vh] pb-[100vh]">
      <div class="process-steps-container space-y-32">
        {landingData.processSteps.map((step, index) => (
          <div class={`process-step bg-slate-950/80 backdrop-blur-xl border border-slate-800/80 p-6 sm:p-8 md:p-12 rounded-3xl shadow-[0_0_50px_rgba(0,0,0,0.5)] hover:border-blue-500/40 transition-colors duration-500 relative overflow-hidden group w-[85%] sm:w-[400px] md:w-[450px] aspect-square flex flex-col justify-end ${index % 2 === 0 ? 'mr-auto' : 'ml-auto'}`}>
            
            <!-- Large Outlined Number -->
            <div class="absolute -top-8 -left-4 sm:-top-12 sm:-left-6 text-[15rem] sm:text-[22rem] md:text-[28rem] tracking-tighter font-bold  leading-none select-none text-transparent [-webkit-text-stroke:2px_theme(colors.slate.800)] group-hover:[-webkit-text-stroke:2px_theme(colors.blue.500)] transition-all duration-500 z-0 pointer-events-none">
              {step.n}
            </div>

            <div class="flex flex-col text-left space-y-3 relative z-10 mt-auto">
              <h3 class="text-2xl md:text-3xl font-bold text-white ">{step.title}</h3>
              <p class="text-slate-300 text-base md:text-lg leading-relaxed">{step.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>




