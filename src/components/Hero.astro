---
import { landingData } from '../data/landing';
import heroPattern from '../assets/hero-patternv1.1.svg';
---

<section class="relative min-h-[90vh] flex flex-col justify-center bg-slate-950 text-white pt-32 pb-16 overflow-hidden">
  <!-- Decoración geométrica SVG en la parte derecha -->
  <div class="absolute top-0 right-0 w-full md:w-3/5 lg:w-[45%] h-full pointer-events-none z-0 overflow-hidden [mask-image:linear-gradient(to_bottom,black_60%,transparent_100%)]" style="clip-path: polygon(25% 0, 100% 0, 100% 100%, 0% 100%);">
    <img src={heroPattern.src} alt="Patrón geométrico Narez" class="absolute inset-0 w-full h-full object-cover" />
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 w-full">
    <div class="max-w-4xl">
      <!-- Tipografa Gigante Fluida -->
      <h1 class="text-[clamp(2rem,5vw,4.5rem)] font-bold uppercase leading-[1] tracking-tighter mb-8">
        <span class="block opacity-0 translate-y-8 animate-[fade-in-up_0.8s_0.2s_forwards]">{landingData.hero.title.replace(landingData.hero.highlight, '')}</span>
        <span class="block text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-blue-600 opacity-0 translate-y-8 animate-[fade-in-up_0.8s_0.4s_forwards] mt-2">
          {landingData.hero.highlight}
        </span>
      </h1>
      
      <p class="mt-8 text-[clamp(1.125rem,2.5vw,1.875rem)] text-slate-300 max-w-3xl leading-snug font-medium opacity-0 translate-y-8 animate-[fade-in-up_0.8s_0.6s_forwards]">
        {landingData.hero.description}
      </p>
      
      <div class="mt-14 flex flex-col sm:flex-row gap-6 opacity-0 translate-y-8 animate-[fade-in-up_0.8s_0.8s_forwards]">
        <a href="#contacto" class="group flex items-center justify-between px-10 py-5 text-lg font-semibold text-white bg-blue-600 hover:bg-blue-700 transition duration-300 ease-in-out w-full sm:w-auto">
          <span class="uppercase tracking-widest">{landingData.hero.primaryCta}</span>
          <svg class="w-6 h-6 ml-6 transform group-hover:translate-x-2 transition-transform" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="square" stroke-linejoin="miter" d="M9 5l7 7-7 7"></path></svg>
        </a>
      </div>
    </div>
  </div>
</section>
