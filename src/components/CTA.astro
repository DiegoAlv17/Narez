---
import { landingData } from '../data/landing';
---

<section id="contacto" class="py-32 bg-blue-900 text-white relative overflow-hidden">
  <!-- Fondo decorativo sutil -->
  <div class="absolute inset-0 opacity-20 pointer-events-none">
     <div class="absolute -top-1/2 -right-1/4 w-full h-full bg-blue-500 blur-[200px] rounded-full"></div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <div>
        <h2 class="text-6xl md:text-7xl lg:text-[6rem] font-black uppercase tracking-tighter leading-[0.9] mb-8">
          {landingData.cta.title}
        </h2>
        <p class="text-xl md:text-2xl text-blue-100 font-medium leading-relaxed max-w-lg">
          {landingData.cta.description}
        </p>
      </div>
      <div class="flex justify-start lg:justify-end">
         <a href="mailto:hola@narez.com" class="group flex items-center justify-between px-10 py-6 text-xl font-black text-blue-950 bg-white hover:bg-slate-100 transition duration-300 ease-in-out">
            <span class="uppercase tracking-widest">{landingData.cta.buttonText}</span>
            <svg class="w-8 h-8 ml-6 transform group-hover:translate-x-3 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="square" stroke-linejoin="miter" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
         </a>
      </div>
    </div>
  </div>
</section>
